nt-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;• translate_me_the_chosen_one_30Sep.py&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;KLARAKARBON&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;• Klarakarbon_code3.py&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;• Klarakarbon_categories_last_one.py&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;• Klarakarbond_double_counting_05_november.py&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;TRAVEL&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;• extract_and_standardize_raw_data.py&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;• analysis_report.py&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;• clean_source_data.py&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" link="BOOKLETS&#xa;&#xa;&#xa;• the_chosen_one_11November.py&#xa;&#xa;&#xa;• Clean_me_the_chosen_one_3Oct.py&#xa;&#xa;&#xa;• normalized10.py&#xa;&#xa;&#xa;• Currency_converter_03Oct.py&#xa;&#xa;&#xa;• translate_me_the_chosen_one_30Sep.py&#xa;&#xa;&#xa;KLARAKARBON&#xa;&#xa;&#xa;• Klarakarbon_code3.py&#xa;&#xa;&#xa;• Klarakarbon_categories_last_one.py&#xa;&#xa;&#xa;• Klarakarbond_double_counting_05_november.py&#xa;&#xa;&#xa;TRAVEL&#xa;&#xa;&#xa;• extract_and_standardize_raw_data.py&#xa;&#xa;&#xa;• analysis_report.py&#xa;&#xa;&#xa;• clean_source_data.py" id="162">
                    <mxCell style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;" parent="1" vertex="1">
                        <mxGeometry x="-2217" y="-121" width="411.46" height="906" as="geometry"/>
                    </mxCell>
                </UserObject>
                <mxCell id="163" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;MAPPING&lt;/b&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;468&quot; data-start=&quot;465&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• main_mapping.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;488&quot; data-start=&quot;485&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• mapping_utils.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;509&quot; data-start=&quot;506&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• __map_ratio.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-is-only-node=&quot;&quot; data-end=&quot;528&quot; data-start=&quot;525&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• __report_totals.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;551&quot; data-start=&quot;548&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• aggregate_company_totals.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;583&quot; data-start=&quot;580&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• append_sources_to_mapped.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;615&quot; data-start=&quot;612&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• calculate_me_the_chosen_one.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;650&quot; data-start=&quot;647&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• combine_three_sources.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;679&quot; data-start=&quot;676&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• double_countin_booklets.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;710&quot; data-start=&quot;707&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• inspect_cat12.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;731&quot; data-start=&quot;728&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• post_merge_sheets.py&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot; data-end=&quot;756&quot; data-start=&quot;753&quot;&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;• Run_Everything.py&lt;/span&gt;&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="-580" y="-131" width="330" height="657" as="geometry"/>
                </mxCell>
                <mxCell id="192" value="&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;b style=&quot;font-size: 30px; background-color: transparent;&quot;&gt;Sustainability Data Collection &amp;amp; Reporting Pipeline (High Level)&lt;/b&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="-1701.9" y="-2915" width="970" height="102.38" as="geometry"/>
                </mxCell>
                <UserObject label="&lt;p data-end=&quot;848&quot; data-start=&quot;145&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center;&quot; data-end=&quot;848&quot; data-start=&quot;145&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;1) BOOKLETS&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;848&quot; data-start=&quot;145&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;1) the_chosen_one_11November.py&lt;/b&gt;&lt;br data-end=&quot;176&quot; data-start=&quot;173&quot;&gt;&lt;br&gt;This script is the entry point of the Booklets pipeline and serves as the foundation of the entire system. It loads raw Excel and CSV files from multiple subsidiaries, normalizes column names, fixes formatting inconsistencies, and performs the first major cleaning stage. Because subsidiaries submit data in highly inconsistent formats, this script creates a unified structure that allows all following steps to run without errors. It also performs early quality checks by detecting missing fields, incorrect data types, malformed descriptions, duplicate headers, and placeholder rows. The final output is a standardized base dataset that all downstream modules depend on.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;1475&quot; data-start=&quot;850&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;2) Clean_me_the_chosen_one_3Oct.py&lt;/b&gt;&lt;br data-end=&quot;884&quot; data-start=&quot;881&quot;&gt;&lt;br&gt;This script performs the second deep-cleaning layer after the initial normalization. It focuses on text standardization such as lowercasing, removing symbols, trimming extra spaces, fixing Unicode issues, and sanitizing descriptions. It also ensures numeric consistency and structural alignment across key fields. In addition, it identifies invalid entries, flags anomalies, corrects supplier and category formatting problems, and removes duplicates. This advanced cleaning step greatly strengthens fuzzy matching and later mapping accuracy by enforcing strict text and numerical formatting.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;2021&quot; data-start=&quot;1477&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;3) normalized10.py&lt;/b&gt;&lt;br data-end=&quot;1495&quot; data-start=&quot;1492&quot;&gt;&lt;br&gt;This script merges the outputs of all earlier Booklets and Klarakarbon steps into one unified data structure. It consolidates corrected categories, resolves remaining inconsistencies, and prepares the final dataset that transitions into the Mapping stage. It also generates key columns required by the mapping engine, including final categories, confidence flags, duplicate indicators, and mapping validation fields. The output represents the fully cleaned, structured dataset that feeds directly into emission factor mapping.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;2503&quot; data-start=&quot;2023&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;4) Currency_converter_03Oct.py&lt;/b&gt;&lt;br data-end=&quot;2053&quot; data-start=&quot;2050&quot;&gt;&lt;br&gt;This script standardizes all monetary values by converting them into EUR. It automatically detects currency information found in both dedicated fields and embedded text. Using a predefined exchange-rate table, it applies the correct conversion rate and fixes malformed numerical formats. It then produces normalized cost columns used in cost-based emission factor calculations and ensures consistent monetary representation across the entire dataset.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;3059&quot; data-start=&quot;2505&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;5) translate_me_the_chosen_one_30Sep.py&lt;/b&gt;&lt;br data-end=&quot;2544&quot; data-start=&quot;2541&quot;&gt;&lt;br&gt;This script handles cross-language normalization by translating non-English descriptions, categories, supplier names, and unit fields into English. Many subsidiaries provide mixed-language data, which can distort mapping accuracy and reduce fuzzy-matching effectiveness. After translation, the script cleans and aligns these fields so that the remaining pipeline can process all entries consistently. This ensures that multilingual inputs do not negatively impact emission factor mapping or downstream data quality.&lt;/font&gt;&lt;/p&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;&lt;/font&gt;" link="&#xa;&lt;p data-end=&quot;848&quot; data-start=&quot;145&quot;&gt;the_chosen_one_11November.py&lt;br data-end=&quot;176&quot; data-start=&quot;173&quot;&gt;&#xa;This script is the entry point of the Booklets pipeline and serves as the foundation of the entire system. It loads raw Excel and CSV files from multiple subsidiaries, normalizes column names, fixes formatting inconsistencies, and performs the first major cleaning stage. Because subsidiaries submit data in highly inconsistent formats, this script creates a unified structure that allows all following steps to run without errors. It also performs early quality checks by detecting missing fields, incorrect data types, malformed descriptions, duplicate headers, and placeholder rows. The final output is a standardized base dataset that all downstream modules depend on.&lt;/p&gt;&#xa;&lt;p data-end=&quot;1475&quot; data-start=&quot;850&quot;&gt;Clean_me_the_chosen_one_3Oct.py&lt;br data-end=&quot;884&quot; data-start=&quot;881&quot;&gt;&#xa;This script performs the second deep-cleaning layer after the initial normalization. It focuses on text standardization such as lowercasing, removing symbols, trimming extra spaces, fixing Unicode issues, and sanitizing descriptions. It also ensures numeric consistency and structural alignment across key fields. In addition, it identifies invalid entries, flags anomalies, corrects supplier and category formatting problems, and removes duplicates. This advanced cleaning step greatly strengthens fuzzy matching and later mapping accuracy by enforcing strict text and numerical formatting.&lt;/p&gt;&#xa;&lt;p data-end=&quot;2021&quot; data-start=&quot;1477&quot;&gt;normalized10.py&lt;br data-end=&quot;1495&quot; data-start=&quot;1492&quot;&gt;&#xa;This script merges the outputs of all earlier Booklets and Klarakarbon steps into one unified data structure. It consolidates corrected categories, resolves remaining inconsistencies, and prepares the final dataset that transitions into the Mapping stage. It also generates key columns required by the mapping engine, including final categories, confidence flags, duplicate indicators, and mapping validation fields. The output represents the fully cleaned, structured dataset that feeds directly into emission factor mapping.&lt;/p&gt;&#xa;&lt;p data-end=&quot;2503&quot; data-start=&quot;2023&quot;&gt;Currency_converter_03Oct.py&lt;br data-end=&quot;2053&quot; data-start=&quot;2050&quot;&gt;&#xa;This script standardizes all monetary values by converting them into EUR. It automatically detects currency information found in both dedicated fields and embedded text. Using a predefined exchange-rate table, it applies the correct conversion rate and fixes malformed numerical formats. It then produces normalized cost columns used in cost-based emission factor calculations and ensures consistent monetary representation across the entire dataset.&lt;/p&gt;&#xa;&lt;p data-end=&quot;3059&quot; data-start=&quot;2505&quot;&gt;translate_me_the_chosen_one_30Sep.py&lt;br data-end=&quot;2544&quot; data-start=&quot;2541&quot;&gt;&#xa;This script handles cross-language normalization by translating non-English descriptions, categories, supplier names, and unit fields into English. Many subsidiaries provide mixed-language data, which can distort mapping accuracy and reduce fuzzy-matching effectiveness. After translation, the script cleans and aligns these fields so that the remaining pipeline can process all entries consistently. This ensures that multilingual inputs do not negatively impact emission factor mapping or downstream data quality.&lt;/p&gt;&#xa;&#xa;" id="236">
                    <mxCell style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=0;align=left;" vertex="1" parent="1">
                        <mxGeometry x="-1772" y="-121" width="570.1" height="1223" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); font-size: 18px; background-color: transparent;&quot;&gt;2) KLARAKARBON&lt;/b&gt;&lt;/div&gt;&lt;p data-end=&quot;686&quot; data-start=&quot;156&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;1) Klarakarbon_code3.py&lt;/b&gt;&lt;br data-end=&quot;179&quot; data-start=&quot;176&quot;&gt;&lt;br&gt;This script is the first advanced Klarakarbon normalization module. It analyzes the category fields, corrects inconsistent variations, resolves formatting errors, and aligns all entries with the official Klarakarbon classification system. It also performs category-specific cleaning, checks supplier alignment, and detects anomalies, especially in complex or high-risk categories. The goal is to ensure that all Klarakarbon categories follow a consistent and standardized structure before deeper processing.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;1145&quot; data-start=&quot;688&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;2) Klarakarbon_categories_last_one.py&lt;/b&gt;&lt;br data-end=&quot;725&quot; data-start=&quot;722&quot;&gt;&lt;br&gt;This script performs the final Klarakarbon category validation step. It reviews all remaining category inconsistencies and forces each value to match the official standard classification. It also handles detailed edge-case corrections, including minor typo fixes, whitespace normalization, and removing unnecessary prefixes or postfixes. After this step, all category fields are fully standardized and ready for mapping.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;1715&quot; data-start=&quot;1147&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;3) Klarakarbond_double_counting_05_november.py&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;1715&quot; data-start=&quot;1147&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;This module identifies duplicate category entries, especially in Category 12, where service-based items often appear more than once. It detects potential or confirmed double-counting by comparing descriptions, supplier names, units, quantities, emission factor categories, and dates. The script flags duplicates, generates detailed reports, and can optionally remove or merge overlapping records. This ensures that the final dataset is clean, non-duplicated, and prevents inflated emission totals during the mapping stage.&lt;/font&gt;&lt;/p&gt;" link="&#xa;&lt;p data-end=&quot;686&quot; data-start=&quot;156&quot;&gt;Klarakarbon_code3.py&lt;br data-end=&quot;179&quot; data-start=&quot;176&quot;&gt;&#xa;This script is the first advanced Klarakarbon normalization module. It analyzes the category fields, corrects inconsistent variations, resolves formatting errors, and aligns all entries with the official Klarakarbon classification system. It also performs category-specific cleaning, checks supplier alignment, and detects anomalies, especially in complex or high-risk categories. The goal is to ensure that all Klarakarbon categories follow a consistent and standardized structure before deeper processing.&lt;/p&gt;&#xa;&lt;p data-end=&quot;1145&quot; data-start=&quot;688&quot;&gt;Klarakarbon_categories_last_one.py&lt;br data-end=&quot;725&quot; data-start=&quot;722&quot;&gt;&#xa;This script performs the final Klarakarbon category validation step. It reviews all remaining category inconsistencies and forces each value to match the official standard classification. It also handles detailed edge-case corrections, including minor typo fixes, whitespace normalization, and removing unnecessary prefixes or postfixes. After this step, all category fields are fully standardized and ready for mapping.&lt;/p&gt;&#xa;&lt;p data-end=&quot;1715&quot; data-start=&quot;1147&quot;&gt;Klarakarbond_double_counting_05_november.py&lt;br data-end=&quot;1193&quot; data-start=&quot;1190&quot;&gt;&#xa;This module identifies duplicate category entries, especially in Category 12, where service-based items often appear more than once. It detects potential or confirmed double-counting by comparing descriptions, supplier names, units, quantities, emission factor categories, and dates. The script flags duplicates, generates detailed reports, and can optionally remove or merge overlapping records. This ensures that the final dataset is clean, non-duplicated, and prevents inflated emission totals during the mapping stage.&lt;/p&gt;&#xa;&#xa;" id="238">
                    <mxCell style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=0;align=left;" vertex="1" parent="1">
                        <mxGeometry x="-1178.1" y="-125" width="570.1" height="700" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); font-size: 18px; background-color: transparent;&quot;&gt;3) TRAVEL&lt;/b&gt;&lt;/div&gt;&lt;p data-end=&quot;616&quot; data-start=&quot;141&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;1) extract_and_standardize_raw_data.py&lt;/b&gt;&lt;br data-end=&quot;179&quot; data-start=&quot;176&quot;&gt;&lt;br&gt;This script ingests raw business travel files, detects all valid sheets, extracts them, and converts them into a standardized format. It fixes headers, normalizes column names, trims invalid or incomplete rows, and ensures that travel data from different regions follows the same structure. The result is a clean and unified “travel raw dataset,” which forms the foundation for accurate travel emission factor calculations and reporting.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;1114&quot; data-start=&quot;618&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;2) analysis_report.py&lt;/b&gt;&lt;br data-end=&quot;639&quot; data-start=&quot;636&quot;&gt;&lt;br&gt;This module evaluates the structure, quality, and completeness of the travel dataset. It detects missing values, invalid or impossible travel entries, inconsistent units, and incorrect route or carrier information. The script then produces detailed QC and validation reports that highlight issues requiring correction before emissions are calculated. This ensures that all travel data meets corporate sustainability reporting standards and is reliable for further processing.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;1626&quot; data-start=&quot;1116&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;3) clean_source_data.py&lt;/b&gt;&lt;br data-end=&quot;1139&quot; data-start=&quot;1136&quot;&gt;&lt;br&gt;This script harmonizes travel data collected from different subsidiaries by correcting column mismatches, removing corrupted or unusable rows, and standardizing formatting differences. Since subsidiaries often use different templates or reporting styles, the script enforces a consistent schema across all travel data. This unified structure enables the mapping stage to apply accurate emission factors to each travel segment, including flights, car trips, bus journeys, and rail travel.&lt;/font&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" link="&#xa;&lt;p data-end=&quot;616&quot; data-start=&quot;141&quot;&gt;extract_and_standardize_raw_data.py&lt;br data-end=&quot;179&quot; data-start=&quot;176&quot;&gt;&#xa;This script ingests raw business travel files, detects all valid sheets, extracts them, and converts them into a standardized format. It fixes headers, normalizes column names, trims invalid or incomplete rows, and ensures that travel data from different regions follows the same structure. The result is a clean and unified “travel raw dataset,” which forms the foundation for accurate travel emission factor calculations and reporting.&lt;/p&gt;&#xa;&lt;p data-end=&quot;1114&quot; data-start=&quot;618&quot;&gt;analysis_report.py&lt;br data-end=&quot;639&quot; data-start=&quot;636&quot;&gt;&#xa;This module evaluates the structure, quality, and completeness of the travel dataset. It detects missing values, invalid or impossible travel entries, inconsistent units, and incorrect route or carrier information. The script then produces detailed QC and validation reports that highlight issues requiring correction before emissions are calculated. This ensures that all travel data meets corporate sustainability reporting standards and is reliable for further processing.&lt;/p&gt;&#xa;&lt;p data-end=&quot;1626&quot; data-start=&quot;1116&quot;&gt;clean_source_data.py&lt;br data-end=&quot;1139&quot; data-start=&quot;1136&quot;&gt;&#xa;This script harmonizes travel data collected from different subsidiaries by correcting column mismatches, removing corrupted or unusable rows, and standardizing formatting differences. Since subsidiaries often use different templates or reporting styles, the script enforces a consistent schema across all travel data. This unified structure enables the mapping stage to apply accurate emission factors to each travel segment, including flights, car trips, bus journeys, and rail travel.&lt;/p&gt;&#xa;&#xa;" id="239">
                    <mxCell style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=0;align=left;" vertex="1" parent="1">
                        <mxGeometry x="-1182" y="593" width="569" height="684" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); font-size: 18px; background-color: transparent;&quot;&gt;MAPPING&lt;/b&gt;&lt;/div&gt;&lt;p data-end=&quot;759&quot; data-start=&quot;185&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;1) main_mapping.py&lt;/b&gt;&lt;br data-end=&quot;203&quot; data-start=&quot;200&quot;&gt;&lt;br&gt;This script is the core of the mapping engine. It loads the fully normalized dataset and applies exact matching, fuzzy matching, supplier-based logic, category rules, and fallback algorithms to assign the most accurate emission factor to every row. It calculates mapping confidence scores, distinguishes successfully and unsuccessfully mapped records, applies unit conversions, and generates the final CO2e emission values. The resulting mapped dataset becomes the backbone of corporate sustainability reporting and is used directly in Power BI dashboards.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;1197&quot; data-start=&quot;761&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;2) mapping_utils.py&lt;/b&gt;&lt;br data-end=&quot;780&quot; data-start=&quot;777&quot;&gt;&lt;br&gt;This module provides all helper functions that support the mapping engine. It includes advanced text-normalization utilities, fuzzy-matching algorithms, unit-conversion logic, emission-factor lookup functions, and mapping-confidence scoring tools. These utilities power the decision-making logic inside main_mapping.py and significantly improve accuracy when identifying the correct emission factor for each activity.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;1572&quot; data-start=&quot;1199&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;3) map_ratio.py&lt;/b&gt;&lt;br data-end=&quot;1216&quot; data-start=&quot;1213&quot;&gt;&lt;br&gt;This script manages ratio-based emission factors, where emissions are calculated using ratios instead of quantities. Examples include kgCO2e per EUR spent or service-based multipliers. It ensures these ratio rules are applied consistently, especially for Category 12 and other service-heavy categories where traditional quantity-based methods do not apply.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;1917&quot; data-start=&quot;1574&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;4) report_totals.py&lt;/b&gt;&lt;br data-end=&quot;1595&quot; data-start=&quot;1592&quot;&gt;&lt;br&gt;This module calculates emission totals by company, category, supplier, or project. It produces aggregated outputs needed for dashboards, reporting packages, and executive summaries. It also validates the completeness of mapped data by comparing emission totals before and after mapping to identify gaps or inconsistencies.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;2292&quot; data-start=&quot;1919&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;5) aggregate_company_totals.py&lt;/b&gt;&lt;br data-end=&quot;1949&quot; data-start=&quot;1946&quot;&gt;&lt;br&gt;This script performs high-level aggregation of cleaned and merged data before mapping begins. It analyzes distribution patterns, supplier concentration, category anomalies, and data-quality gaps. Its summary outputs serve as important checkpoints that verify whether the raw and cleaned datasets are ready for accurate emission factor mapping.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;2689&quot; data-start=&quot;2294&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;6) append_sources_to_mapped.py&lt;/b&gt;&lt;br data-end=&quot;2324&quot; data-start=&quot;2321&quot;&gt;&lt;br&gt;This module attaches metadata—such as source company, original sheet name, file name, and other identifiers—to the final mapped dataset. It ensures complete traceability from the final emission values back to the original source files. This traceability is essential for audits, transparency, troubleshooting, and compliance with sustainability reporting standards.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;3031&quot; data-start=&quot;2691&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;7) calculate_me_the_chosen_one.py&lt;/b&gt;&lt;br data-end=&quot;2724&quot; data-start=&quot;2721&quot;&gt;&lt;br&gt;This script applies all final numeric calculations on the mapped dataset. It runs multipliers, adjusts for unit conversions, combines intermediate components, and computes derived metrics. By applying these post-mapping formulas consistently, it ensures the dataset is fully calculation-ready for reporting.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;3334&quot; data-start=&quot;3033&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;8) combine_three_sources.py&lt;/b&gt;&lt;br data-end=&quot;3060&quot; data-start=&quot;3057&quot;&gt;&lt;br&gt;This module merges three different data sources—Booklets, Travel, and additional datasets—into a single unified structure. It aligns all fields so that Scope 1, Scope 2, and Scope 3 categories can be calculated within one combined dataset, without losing detail or metadata.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;3636&quot; data-start=&quot;3336&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;9) double_countin_booklets.py&lt;/b&gt;&lt;br data-end=&quot;3365&quot; data-start=&quot;3362&quot;&gt;&lt;br&gt;This script checks for double-counting after the mapping process. It ensures that the mapping workflow has not reintroduced duplicates or conflicting entries. It serves as a final quality-control checkpoint to prevent inflated or duplicated emissions in the final output.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;3957&quot; data-start=&quot;3638&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;10) inspect_cat12.py&lt;/b&gt;&lt;br data-end=&quot;3657&quot; data-start=&quot;3654&quot;&gt;&lt;br&gt;This module performs a detailed diagnostic review of Category 12 after mapping. It identifies unusual mappings, suspicious supplier descriptions, incorrect EF selections, and potential double-counting. It helps ensure that Category 12—one of the most complex categories—remains accurate and reliable.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;4244&quot; data-start=&quot;3959&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;11) post_merge_sheets.py&lt;/b&gt;&lt;br data-end=&quot;3982&quot; data-start=&quot;3979&quot;&gt;&lt;br&gt;This script consolidates multiple sheets into a single structured table before the main mapping process. It detects valid sheets, cleans their structure, and aligns all fields so that the mapping logic can run smoothly and consistently across the entire dataset.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;4590&quot; data-start=&quot;4246&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;12) Run_Everything.py&lt;/b&gt;&lt;br data-end=&quot;4266&quot; data-start=&quot;4263&quot;&gt;&lt;br&gt;This master script orchestrates the entire mapping pipeline from start to finish. It runs all modules in the correct order, manages dependencies, and produces the complete end-to-end mapped dataset. At the end of the process, it generates a final consolidated report ready for internal and external sustainability reporting.&lt;/font&gt;&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" link="&#xa;&lt;p data-end=&quot;759&quot; data-start=&quot;185&quot;&gt;main_mapping.py&lt;br data-end=&quot;203&quot; data-start=&quot;200&quot;&gt;&#xa;This script is the core of the mapping engine. It loads the fully normalized dataset and applies exact matching, fuzzy matching, supplier-based logic, category rules, and fallback algorithms to assign the most accurate emission factor to every row. It calculates mapping confidence scores, distinguishes successfully and unsuccessfully mapped records, applies unit conversions, and generates the final CO2e emission values. The resulting mapped dataset becomes the backbone of corporate sustainability reporting and is used directly in Power BI dashboards.&lt;/p&gt;&#xa;&lt;p data-end=&quot;1197&quot; data-start=&quot;761&quot;&gt;mapping_utils.py&lt;br data-end=&quot;780&quot; data-start=&quot;777&quot;&gt;&#xa;This module provides all helper functions that support the mapping engine. It includes advanced text-normalization utilities, fuzzy-matching algorithms, unit-conversion logic, emission-factor lookup functions, and mapping-confidence scoring tools. These utilities power the decision-making logic inside main_mapping.py and significantly improve accuracy when identifying the correct emission factor for each activity.&lt;/p&gt;&#xa;&lt;p data-end=&quot;1572&quot; data-start=&quot;1199&quot;&gt;__map_ratio.py&lt;br data-end=&quot;1216&quot; data-start=&quot;1213&quot;&gt;&#xa;This script manages ratio-based emission factors, where emissions are calculated using ratios instead of quantities. Examples include kgCO2e per EUR spent or service-based multipliers. It ensures these ratio rules are applied consistently, especially for Category 12 and other service-heavy categories where traditional quantity-based methods do not apply.&lt;/p&gt;&#xa;&lt;p data-end=&quot;1917&quot; data-start=&quot;1574&quot;&gt;__report_totals.py&lt;br data-end=&quot;1595&quot; data-start=&quot;1592&quot;&gt;&#xa;This module calculates emission totals by company, category, supplier, or project. It produces aggregated outputs needed for dashboards, reporting packages, and executive summaries. It also validates the completeness of mapped data by comparing emission totals before and after mapping to identify gaps or inconsistencies.&lt;/p&gt;&#xa;&lt;p data-end=&quot;2292&quot; data-start=&quot;1919&quot;&gt;aggregate_company_totals.py&lt;br data-end=&quot;1949&quot; data-start=&quot;1946&quot;&gt;&#xa;This script performs high-level aggregation of cleaned and merged data before mapping begins. It analyzes distribution patterns, supplier concentration, category anomalies, and data-quality gaps. Its summary outputs serve as important checkpoints that verify whether the raw and cleaned datasets are ready for accurate emission factor mapping.&lt;/p&gt;&#xa;&lt;p data-end=&quot;2689&quot; data-start=&quot;2294&quot;&gt;append_sources_to_mapped.py&lt;br data-end=&quot;2324&quot; data-start=&quot;2321&quot;&gt;&#xa;This module attaches metadata—such as source company, original sheet name, file name, and other identifiers—to the final mapped dataset. It ensures complete traceability from the final emission values back to the original source files. This traceability is essential for audits, transparency, troubleshooting, and compliance with sustainability reporting standards.&lt;/p&gt;&#xa;&lt;p data-end=&quot;3031&quot; data-start=&quot;2691&quot;&gt;calculate_me_the_chosen_one.py&lt;br data-end=&quot;2724&quot; data-start=&quot;2721&quot;&gt;&#xa;This script applies all final numeric calculations on the mapped dataset. It runs multipliers, adjusts for unit conversions, combines intermediate components, and computes derived metrics. By applying these post-mapping formulas consistently, it ensures the dataset is fully calculation-ready for reporting.&lt;/p&gt;&#xa;&lt;p data-end=&quot;3334&quot; data-start=&quot;3033&quot;&gt;combine_three_sources.py&lt;br data-end=&quot;3060&quot; data-start=&quot;3057&quot;&gt;&#xa;This module merges three different data sources—Booklets, Travel, and additional datasets—into a single unified structure. It aligns all fields so that Scope 1, Scope 2, and Scope 3 categories can be calculated within one combined dataset, without losing detail or metadata.&lt;/p&gt;&#xa;&lt;p data-end=&quot;3636&quot; data-start=&quot;3336&quot;&gt;double_countin_booklets.py&lt;br data-end=&quot;3365&quot; data-start=&quot;3362&quot;&gt;&#xa;This script checks for double-counting after the mapping process. It ensures that the mapping workflow has not reintroduced duplicates or conflicting entries. It serves as a final quality-control checkpoint to prevent inflated or duplicated emissions in the final output.&lt;/p&gt;&#xa;&lt;p data-end=&quot;3957&quot; data-start=&quot;3638&quot;&gt;inspect_cat12.py&lt;br data-end=&quot;3657&quot; data-start=&quot;3654&quot;&gt;&#xa;This module performs a detailed diagnostic review of Category 12 after mapping. It identifies unusual mappings, suspicious supplier descriptions, incorrect EF selections, and potential double-counting. It helps ensure that Category 12—one of the most complex categories—remains accurate and reliable.&lt;/p&gt;&#xa;&lt;p data-end=&quot;4244&quot; data-start=&quot;3959&quot;&gt;post_merge_sheets.py&lt;br data-end=&quot;3982&quot; data-start=&quot;3979&quot;&gt;&#xa;This script consolidates multiple sheets into a single structured table before the main mapping process. It detects valid sheets, cleans their structure, and aligns all fields so that the mapping logic can run smoothly and consistently across the entire dataset.&lt;/p&gt;&#xa;&lt;p data-end=&quot;4590&quot; data-start=&quot;4246&quot;&gt;Run_Everything.py&lt;br data-end=&quot;4266&quot; data-start=&quot;4263&quot;&gt;&#xa;This master script orchestrates the entire mapping pipeline from start to finish. It runs all modules in the correct order, manages dependencies, and produces the complete end-to-end mapped dataset. At the end of the process, it generates a final consolidated report ready for internal and external sustainability reporting.&lt;/p&gt;&#xa;&#xa;" id="240">
                    <mxCell style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;" vertex="1" parent="1">
                        <mxGeometry x="-233" y="-131" width="774" height="1791" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="&lt;div&gt;&lt;p data-end=&quot;996&quot; data-start=&quot;408&quot;&gt;&lt;/p&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;color: rgb(63, 63, 63); font-size: 18px; background-color: transparent;&quot;&gt;Purpose and Output&lt;/b&gt;&lt;/div&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;br&gt;The purpose of main_mapping.py is to match every activity or spend row with the correct Emission Factor (EF), based on the sheet type, country, keywords, and special rules. The script fills all EF-related fields, such as ef_id, ef_name, ef_unit, ef_value, and ef_source. When the EF unit is Euro-based, the script also calculates tCO2e emissions for each line. After processing all sheets, the script writes a full mapped Excel file (mapped_results.xlsx). It then triggers additional calculation and merge modules to produce a final consolidated output for reporting.&lt;/font&gt;&lt;p&gt;&lt;/p&gt;&lt;p data-end=&quot;1595&quot; data-start=&quot;998&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;I&lt;b&gt;nput Workbooks and References&lt;/b&gt;&lt;br data-end=&quot;1031&quot; data-start=&quot;1028&quot;&gt;&lt;br&gt;The script uses the latest version of the normalized input workbook (normalized_emission_factor_mapping_translated_*.xlsx). It loads the full EF dictionary from CTS_Emission_factors_short_list.xlsx using mapping_utils.load_emission_factors, which reads all EF sheets inside that file. It also supports manual override workbooks such as Correct mapping example.xlsx and additional override files for BIMMS and CTS Denmark. For Scope 3 Category 7 (Employee Commute), the script can optionally load a headcount file (headcount_info.csv) to generate synthetic records.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;2184&quot; data-start=&quot;1597&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Cat 7 Pre-Processing&lt;/b&gt;&lt;br data-end=&quot;1620&quot; data-start=&quot;1617&quot;&gt;&lt;br&gt;If CAT7_PREPROCESS_ENABLED is set to True, the script performs a special preprocessing step for Scope 3 Cat 7 Employee Commute. It removes rows that have an empty “Mode of Transport,” calculates transport-mode ratios for each company and month, and generates synthetic entries so that the number of records matches total headcount. It also expands incomplete months, such as creating missing months for Fortica (October–December). At this stage, EF fields are not assigned yet; the goal is only to prepare a clean and complete Cat 7 dataset for the mapping engine.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;2683&quot; data-start=&quot;2186&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;EF Dictionary Loading and EF-Value Backfilling&lt;/b&gt;&lt;br data-end=&quot;2235&quot; data-start=&quot;2232&quot;&gt;&lt;br&gt;After loading the EF dictionary, the script creates a fast lookup table for selected EF sheets: Purchased Service Spend and Purchased Goods Spend. When processing Category 1 sheets (Cat 1 Services and Cat 1 Goods), if an EF-ID is already present but EF-Value is missing, the script fills the EF-Value automatically from this lookup. This backfilling ensures that the mapping engine does not fail due to incomplete EF-Value fields in Cat 1 datasets.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;3110&quot; data-start=&quot;2685&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Dropped and Excluded Sheets&lt;/b&gt;&lt;br data-end=&quot;2715&quot; data-start=&quot;2712&quot;&gt;&lt;br&gt;The script contains two lists that define which sheets should not be processed. Sheets in DROP_SHEETS are completely skipped and do not appear in the output. Sheets in EXCLUDED_SHEETS are included in the output but are not mapped; instead, they are marked with a status such as “Excluded from mapping.” This helps avoid processing non-GHG sheets or sheets that should not use the mapping engine.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;3939&quot; data-start=&quot;3112&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Sheet-Level Mapping Flow&lt;/b&gt;&lt;br data-end=&quot;3139&quot; data-start=&quot;3136&quot;&gt;&lt;br&gt;For each sheet, the script starts by copying the sheet, adding a “Sheet” column, and re-cleaning empty Mode rows for Cat 7. It automatically detects the Spend column (e.g., Spend_Euro, Spend EUR, Total Spend). The script first checks whether the sheet structure matches a manual override file. If the override matches exactly, the EF fields are taken directly from the override file. If the row count does not match, overrides are disabled. The script then applies Bill-of-Quantities (BoQ) logic when BoQ information is available. Exact BoQ matches override the automatic engine. For BIMMS and CTS Denmark sheets, the script applies additional rules based on exact matching of TFM Code, Product Type, or Service Provided. Rows that are not matched by any rule proceed to the automatic mapping engine.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;4706&quot; data-start=&quot;3941&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Automatic Mapping Engine&lt;/b&gt;&lt;br data-end=&quot;3968&quot; data-start=&quot;3965&quot;&gt;&lt;br&gt;The core automatic matching logic lives inside mapping_utils.map_emission_factor(row, ef_dict). The engine selects the relevant EF sheets based on the sheet name and applies a series of matching rules. These include country detection, keyword matching, product type matching, and specific rules for certain scopes and categories. Special rules are used for Business Travel (Cat 6), Employee Commute (Cat 7), Capital Goods (Cat 2 fixed factor), and End-of-Life (Cat 12). For Category 1 (Goods and Services), the engine applies a sequence of exact matching, “contains” matching, and fuzzy matching (≥0.92 similarity). For Scope 2 Electricity and District Heating, the engine matches only by country and does not fall back to global factors.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;5088&quot; data-start=&quot;4708&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Category 1 Goods/Services Fallback&lt;/b&gt;&lt;br data-end=&quot;4745&quot; data-start=&quot;4742&quot;&gt;&lt;br&gt;If the automatic mapping engine cannot find a match for Category 1 Goods or Services, the script performs a final fallback step. It checks the “All together” EF sheet and attempts an exact Product Type match. This fallback is intentionally strict and only uses exact matching, helping improve coverage without risking incorrect EF assignments.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;5495&quot; data-start=&quot;5090&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Emission Calculation&lt;/b&gt;&lt;br data-end=&quot;5113&quot; data-start=&quot;5110&quot;&gt;&lt;br&gt;Emissions are calculated only when the EF unit is Euro-based. If the unit is kgCO2e/EUR, emissions are calculated as (Spend × EF_value) / 1000 to convert from kg to tonnes. If the unit is tCO2e/EUR, emissions are calculated as Spend × EF_value. If the EF unit is not Euro-based (e.g., kgCO2e/km or kgCO2e/kWh), no emission calculation is performed and emissions_tco2e remains empty.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;5895&quot; data-start=&quot;5497&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Mapped Output&lt;/b&gt;&lt;br data-end=&quot;5513&quot; data-start=&quot;5510&quot;&gt;&lt;br&gt;For every processed sheet, the script adds the following columns: ef_id, ef_name, ef_unit, ef_value, ef_source, match_method, status, and emissions_tco2e. All sheets are combined and written into mapped_results.xlsx. If the file is already open, the script automatically generates a timestamped version. This output represents the complete mapping result before final consolidation.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;6404&quot; data-start=&quot;5897&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Final Merge and Consolidation&lt;/b&gt;&lt;br data-end=&quot;5929&quot; data-start=&quot;5926&quot;&gt;&lt;br&gt;After the mapped output is created, the script calls calculate_me_the_chosen_one.main() to run additional calculations. Then it calls post_merge_sheets.apply_post_mapping_merges(), which merges selected source sheets into target sheets (for example: Cat 8 Fuel into Scope 1 Fuel, Electricity and District Heating into Scope 2 Electricity). This step assigns the final scope, scope_category, and ghg_category fields. The result is written as a new timestamped merged workbook.&lt;/font&gt;&lt;/p&gt;&lt;p data-end=&quot;6889&quot; data-start=&quot;6406&quot;&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Mapping Engine Summary&lt;/b&gt;&lt;br data-end=&quot;6431&quot; data-start=&quot;6428&quot;&gt;&lt;br&gt;The mapping engine applies sheet-specific rules and mapping strategies. Cat 6 uses travel mode or travel type; Cat 7 uses exact transport mode; Cat 2 uses a fixed factor; Cat 12 uses a known EF-ID or fallback; Cat 1 uses exact → contains → fuzzy matching. Scope 2 and District Heating rely on country-exact matching, and fuel/vehicle datasets use keyword matching. The engine is designed to provide high-quality EF matches while avoiding incorrect fallbacks.&lt;/font&gt;&lt;/p&gt;&lt;/div&gt;" link="&#xa;1. main_mapping.py&#xa;This is the core mapping engine. It loads the final normalized dataset and applies exact matching,&#xa;fuzzy matching, supplier-based logic, category logic, and fallback rules to assign the most accurate&#xa;emission factor to each row. It calculates mapping scores, identifies successfully and&#xa;unsuccessfully mapped rows, applies unit conversions, and generates final emission values&#xa;(CO■e). The final mapped file becomes the backbone for corporate reporting and Power BI&#xa;dashboards.&#xa;2. mapping_utils.py&#xa;This module contains all helper functions for the mapping engine: text normalization, fuzzy string&#xa;matching algorithms, unit conversion, emission factor lookup tools, and mapping confidence&#xa;scoring. It powers the decision-making logic inside main_mapping.py, greatly improving accuracy&#xa;and detection of correct emission factor relationships.&#xa;3. __map_ratio.py&#xa;This script handles ratio-based emission factors where emissions are not calculated via quantity but&#xa;via ratio logic (e.g., kg CO■ per EUR spent, or service-based multipliers). It ensures correct ratio&#xa;application across all entries, especially in Category 12 and service-based categories.&#xa;4. __report_totals.py&#xa;This module calculates total emissions per company, category, supplier, or project. It also provides&#xa;aggregated outputs needed for dashboards and executive reporting. It validates the completeness&#xa;of mapped data by comparing totals before and after mapping.&#xa;5. aggregate_company_totals.py&#xa;This script performs high-level aggregation of cleaned and merged data before mapping. It&#xa;identifies distribution patterns, supplier concentration, category anomalies, and data completeness&#xa;gaps. Its summary outputs are critical checkpoints verifying that raw data is ready for mapping.&#xa;6. append_sources_to_mapped.py&#xa;This module attaches metadata source company, sheet name, file name, etc. to the final mapped&#xa;dataset. This ensures full traceability from mapped emission values back to original data sources. It&#xa;is essential for auditability, transparency, and troubleshooting in corporate sustainability workflows.&#xa;7. calculate_me_the_chosen_one.py&#xa;This script performs final numeric calculations on mapped rows. Applying multipliers, combining&#xa;components, adjusting for unit conversions, and computing derived metrics. It ensures all&#xa;post-mapping formulas are applied consistently across the dataset.&#xa;8. combine_three_sources.py&#xa;This module merges three different input sources Booklets, Travel, and additional datasets into one&#xa;integrated structure. It ensures all emission categories (Scope 1, 2, 3) can be calculated in a unified&#xa;dataset without losing structure or metadata.&#xa;9. double_countin_booklets.py&#xa;This version cross-checks for double-counting after the mapping process. It ensures that&#xa;mapping-related operations did not reintroduce duplicates or conflicting entries. It serves as a final&#xa;QC step against duplicate emissions in the final mapped output.&#xa;10. inspect_cat12.py&#xa;This module provides deep diagnostic analysis for Category 12 after mapping. It identifies&#xa;anomalous mappings, suspicious supplier descriptions, incorrect EF matches, and potential&#xa;double-counting cases.&#xa;11. post_merge_sheets.py&#xa;This script merges multiple sheets into a single consistent table before mapping inside the Mapping&#xa;pipeline. It detects valid sheets, cleans them, and aligns their structure so mapping logic can run&#xa;cohesively.&#xa;12. Run_Everything.py&#xa;This master script orchestrates the entire mapping pipeline. It runs all individual modules in the&#xa;correct sequence, manages dependencies, and produces the full end-to-end mapped dataset&#xa;followed by a final report.&#xa;&#xa;" id="244">
                    <mxCell style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;" vertex="1" parent="1">
                        <mxGeometry x="565" y="-129" width="896" height="2056" as="geometry"/>
                    </mxCell>
                </UserObject>
                <mxCell id="253" value="&lt;span&gt;&lt;b&gt;Emission Factor Mapping&amp;nbsp;&lt;/b&gt;&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#cdeb8b;strokeColor=#36393d;fontSize=88;" vertex="1" parent="1">
                    <mxGeometry x="-2681" y="-383" width="4139" height="116" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>